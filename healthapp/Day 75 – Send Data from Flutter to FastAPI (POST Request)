# Step 1

Open

```text
backend/main.py
```

Replace it with this complete file:

```python
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)


class BloodReport(BaseModel):
    patient_name: str
    hemoglobin: float


@app.get("/")
def home():
    return {"message": "Blood Report API is Running"}


@app.get("/report")
def report():
    return {
        "patient_name": "Srujan",
        "hemoglobin": 13.8,
        "hba1c": 6.1,
        "vitamin_d": 18,
    }


@app.post("/submit")
def submit_report(report: BloodReport):
    return {
        "message": "Report received successfully",
        "patient_name": report.patient_name,
        "hemoglobin": report.hemoglobin,
    }
```

Save it.

