# Step 1 – Update `backend/main.py`

Replace your entire `backend/main.py` with the following:

```python
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

from database import Base, engine, SessionLocal
from models import BloodReport

Base.metadata.create_all(bind=engine)

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

class Report(BaseModel):
    patient_name: str
    hemoglobin: float

@app.get("/")
def home():
    return {"message": "Blood Report API Running"}

@app.post("/submit")
def submit(report: Report):

    db = SessionLocal()

    new_report = BloodReport(
        patient_name=report.patient_name,
        hemoglobin=report.hemoglobin,
    )

    db.add(new_report)
    db.commit()
    db.close()

    return {"message": "Saved Successfully"}

@app.get("/reports")
def get_reports():

    db = SessionLocal()

    reports = db.query(BloodReport).all()

    db.close()

    return reports

@app.delete("/reports/{report_id}")
def delete_report(report_id: int):

    db = SessionLocal()

    report = db.query(BloodReport).filter(
        BloodReport.id == report_id
    ).first()

    if report:

        db.delete(report)

        db.commit()

    db.close()

    return {
        "message": "Deleted Successfully"
    }
```

Save it.

