onPressed: () {

  if (selectedFile.isEmpty) {

    ScaffoldMessenger.of(context).showSnackBar(

      const SnackBar(
        content: Text(
          "Please select a report first.",
        ),
      ),

    );

    return;

  }

  Navigator.push(

    context,

    MaterialPageRoute(

      builder: (context) => UploadProgressScreen(
        fileName: selectedFile,
      ),

    ),

  );

},
