```dart
import 'package:flutter/material.dart';

import '../api/api_service.dart';

class AllReportsScreen extends StatefulWidget {
  const AllReportsScreen({super.key});

  @override
  State<AllReportsScreen> createState() =>
      _AllReportsScreenState();
}

class _AllReportsScreenState
    extends State<AllReportsScreen> {

  List reports = [];

  List filteredReports = [];

  bool loading = true;

  @override
  void initState() {

    super.initState();

    loadReports();

  }

  Future<void> loadReports() async {

    setState(() {

      loading = true;

    });

    ApiService api = ApiService();

    reports = await api.getReports();

    filteredReports = List.from(reports);

    setState(() {

      loading = false;

    });

  }

  void searchReports(String value) {

    setState(() {

      if (value.isEmpty) {

        filteredReports = List.from(reports);

      } else {

        filteredReports = reports.where((report) {

          return report["patient_name"]
              .toString()
              .toLowerCase()
              .contains(value.toLowerCase());

        }).toList();

      }

    });

  }

  Future<void> confirmDelete(int id) async {

    bool? delete = await showDialog(

      context: context,

      builder: (context) {

        return AlertDialog(

          title: const Text("Delete Report"),

          content: const Text(
            "Are you sure you want to delete this report?",
          ),

          actions: [

            TextButton(

              onPressed: () {

                Navigator.pop(context, false);

              },

              child: const Text("No"),

            ),

            ElevatedButton(

              onPressed: () {

                Navigator.pop(context, true);

              },

              child: const Text("Yes"),

            ),

          ],

        );

      },

    );

    if (delete == true) {

      ApiService api = ApiService();

      await api.deleteReport(id);

      loadReports();

    }

  }

  @override
  Widget build(BuildContext context) {

    return Scaffold(

      appBar: AppBar(

        title: const Text("Blood Reports"),

      ),

      body: loading

          ? const Center(

              child: CircularProgressIndicator(),

            )

          : Column(

              children: [

                Padding(

                  padding: const EdgeInsets.all(12),

                  child: TextField(

                    onChanged: searchReports,

                    decoration: InputDecoration(

                      hintText: "Search Patient",

                      prefixIcon: const Icon(Icons.search),

                      border: OutlineInputBorder(

                        borderRadius:
                            BorderRadius.circular(10),

                      ),

                    ),

                  ),

                ),

                Expanded(

                  child: ListView.builder(

                    itemCount: filteredReports.length,

                    itemBuilder: (context, index) {

                      return Card(

                        margin: const EdgeInsets.symmetric(

                          horizontal: 10,

                          vertical: 5,

                        ),

                        child: ListTile(

                          leading: const Icon(Icons.person),

                          title: Text(

                            filteredReports[index]["patient_name"],

                          ),

                          subtitle: Text(

                            "Hemoglobin : ${filteredReports[index]["hemoglobin"]}",

                          ),

                          trailing: IconButton(

                            icon: const Icon(

                              Icons.delete,

                              color: Colors.red,

                            ),

                            onPressed: () {

                              confirmDelete(

                                filteredReports[index]["id"],

                              );

                            },

                          ),

                        ),

                      );

                    },

                  ),

                ),

              ],

            ),

    );

  }

}
```

