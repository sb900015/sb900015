# Today's Program

Write this program yourself.

```python
print("=" * 50)
print("        UPDATE PATIENT RECORD")
print("=" * 50)

hospital = []

total = int(input("Enter number of patients: "))

for i in range(total):

    patient = {}

    patient["Name"] = input("Enter Name: ").strip().upper()
    patient["Age"] = int(input("Enter Age: "))
    patient["Blood Group"] = input("Enter Blood Group: ").strip().upper()
    patient["Hemoglobin"] = float(input("Enter Hemoglobin: "))

    hospital.append(patient)

print("\nPatient Records Saved.\n")

search_name = input("Enter patient name to update: ").strip().upper()

found = False

for patient in hospital:

    if patient["Name"] == search_name:

        found = True

        print("\nCurrent Details")
        print(patient)

        new_hemo = float(input("Enter new Hemoglobin: "))

        patient["Hemoglobin"] = new_hemo

        print("\nRecord Updated Successfully!")

        print(patient)

if found == False:
    print("Patient not found.")
```

