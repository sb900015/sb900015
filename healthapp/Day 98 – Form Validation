# Day 98 – Form Validation

**Time:** ~1 hour

## Goal

Improve the Upload Report screen by validating:

* Patient name cannot be empty
* Hemoglobin cannot be empty
* Hemoglobin must be a valid number
* Hemoglobin must be between **0 and 25**

---

# Step 1

Replace the entire file:

```text
lib/screens/post_test_screen.dart
```

with:

```dart
import 'package:flutter/material.dart';

import '../api/api_service.dart';

class PostTestScreen extends StatefulWidget {
  const PostTestScreen({super.key});

  @override
  State<PostTestScreen> createState() =>
      _PostTestScreenState();
}

class _PostTestScreenState
    extends State<PostTestScreen> {

  final _formKey = GlobalKey<FormState>();

  final TextEditingController nameController =
      TextEditingController();

  final TextEditingController hbController =
      TextEditingController();

  bool submitting = false;

  Future<void> submit() async {

    if (!_formKey.currentState!.validate()) {
      return;
    }

    setState(() {
      submitting = true;
    });

    try {

      String message =
          await ApiService().submitReport(

        nameController.text.trim(),

        double.parse(hbController.text),

      );

      if (!mounted) return;

      ScaffoldMessenger.of(context).showSnackBar(

        SnackBar(
          content: Text(message),
        ),

      );

      nameController.clear();
      hbController.clear();

    } catch (e) {

      if (!mounted) return;

      ScaffoldMessenger.of(context).showSnackBar(

        SnackBar(
          content: Text(e.toString()),
        ),

      );

    }

    setState(() {
      submitting = false;
    });

  }

  @override
  Widget build(BuildContext context) {

    return Scaffold(

      appBar: AppBar(

        title: const Text("Upload Report"),

        centerTitle: true,

      ),

      body: Padding(

        padding: const EdgeInsets.all(20),

        child: Form(

          key: _formKey,

          child: Column(

            children: [

              TextFormField(

                controller: nameController,

                decoration: const InputDecoration(

                  labelText: "Patient Name",

                  border: OutlineInputBorder(),

                ),

                validator: (value) {

                  if (value == null ||
                      value.trim().isEmpty) {

                    return "Enter patient name";

                  }

                  return null;

                },

              ),

              const SizedBox(height: 20),

              TextFormField(

                controller: hbController,

                keyboardType:
                    const TextInputType.numberWithOptions(
                  decimal: true,
                ),

                decoration: const InputDecoration(

                  labelText: "Hemoglobin",

                  border: OutlineInputBorder(),

                ),

                validator: (value) {

                  if (value == null ||
                      value.trim().isEmpty) {

                    return "Enter hemoglobin";

                  }

                  final hb =
                      double.tryParse(value);

                  if (hb == null) {

                    return "Enter a valid number";

                  }

                  if (hb < 0 || hb > 25) {

                    return "Hemoglobin must be between 0 and 25";

                  }

                  return null;

                },

              ),

              const SizedBox(height: 30),

              SizedBox(

                width: double.infinity,

                height: 50,

                child: ElevatedButton(

                  onPressed:
                      submitting ? null : submit,

                  child: submitting

                      ? const SizedBox(

                          width: 22,

                          height: 22,

                          child:
                              CircularProgressIndicator(
                            strokeWidth: 2,
                            color: Colors.white,
                          ),

                        )

                      : const Text(

                          "Submit Report",

                          style: TextStyle(
                            fontSize: 18,
                          ),

                        ),

                ),

              ),

            ],

          ),

        ),

      ),

    );

  }

}
```

