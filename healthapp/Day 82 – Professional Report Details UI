## `lib/screens/report_details_screen.dart`

```dart
import 'package:flutter/material.dart';

class ReportDetailsScreen extends StatelessWidget {

  final Map report;

  const ReportDetailsScreen({
    super.key,
    required this.report,
  });

  @override
  Widget build(BuildContext context) {

    double hemoglobin =
        double.parse(report["hemoglobin"].toString());

    String status =
        hemoglobin >= 12 ? "Normal" : "Low";

    Color statusColor =
        hemoglobin >= 12 ? Colors.green : Colors.red;

    return Scaffold(

      appBar: AppBar(
        title: const Text("Blood Report Details"),
      ),

      body: SingleChildScrollView(

        padding: const EdgeInsets.all(20),

        child: Column(

          children: [

            const CircleAvatar(

              radius: 50,

              child: Icon(
                Icons.person,
                size: 60,
              ),

            ),

            const SizedBox(height: 20),

            Text(

              report["patient_name"],

              style: const TextStyle(

                fontSize: 28,

                fontWeight: FontWeight.bold,

              ),

            ),

            const SizedBox(height: 10),

            Container(

              padding: const EdgeInsets.symmetric(
                horizontal: 18,
                vertical: 8,
              ),

              decoration: BoxDecoration(

                color: statusColor,

                borderRadius:
                    BorderRadius.circular(20),

              ),

              child: Text(

                status,

                style: const TextStyle(

                  color: Colors.white,

                  fontWeight: FontWeight.bold,

                  fontSize: 18,

                ),

              ),

            ),

            const SizedBox(height: 30),

            Card(

              elevation: 5,

              child: Padding(

                padding: const EdgeInsets.all(18),

                child: Column(

                  children: [

                    ListTile(

                      leading: const Icon(Icons.numbers),

                      title: const Text("Report ID"),

                      trailing: Text(
                        report["id"].toString(),
                      ),

                    ),

                    const Divider(),

                    ListTile(

                      leading: const Icon(Icons.person),

                      title: const Text("Patient Name"),

                      trailing: Text(
                        report["patient_name"],
                      ),

                    ),

                    const Divider(),

                    ListTile(

                      leading: const Icon(
                        Icons.favorite,
                        color: Colors.red,
                      ),

                      title: const Text("Hemoglobin"),

                      trailing: Text(
                        report["hemoglobin"].toString(),
                      ),

                    ),

                  ],

                ),

              ),

            ),

            const SizedBox(height: 30),

            Card(

              color: Colors.blue.shade50,

              child: const Padding(

                padding: EdgeInsets.all(18),

                child: Text(

                  "More blood parameters such as HbA1c, Vitamin D, Cholesterol, WBC, RBC and AI explanation will be added in the coming days.",

                  style: TextStyle(

                    fontSize: 17,

                  ),

                ),

              ),

            ),

          ],

        ),

      ),

    );

  }

}
```

