## 📄 `report_details_screen.dart`

```dart
import 'package:flutter/material.dart';

import '../models/sample_report.dart';

class ReportDetailsScreen extends StatelessWidget {
  final String fileName;

  const ReportDetailsScreen({
    super.key,
    required this.fileName,
  });

  Widget resultCard(
    String test,
    String value,
    String status,
    Color color,
  ) {
    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: ListTile(
        title: Text(
          test,
          style: const TextStyle(
            fontWeight: FontWeight.bold,
          ),
        ),
        subtitle: Text(value),
        trailing: Text(
          status,
          style: TextStyle(
            color: color,
            fontWeight: FontWeight.bold,
          ),
        ),
      ),
    );
  }

  String hemoglobinStatus() {
    if (sampleReport.hemoglobin >= 12) {
      return "Normal";
    }
    return "Low";
  }

  String hba1cStatus() {
    if (sampleReport.hba1c < 5.7) {
      return "Normal";
    } else if (sampleReport.hba1c < 6.5) {
      return "Pre-Diabetic";
    }
    return "Diabetic";
  }

  String vitaminDStatus() {
    if (sampleReport.vitaminD >= 30) {
      return "Normal";
    }
    return "Low";
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("Blood Report Analysis"),
        centerTitle: true,
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [

            Text(
              sampleReport.patientName,
              style: const TextStyle(
                fontSize: 28,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 5),

            Text(
              fileName,
              style: const TextStyle(
                color: Colors.grey,
              ),
            ),

            const SizedBox(height: 25),

            resultCard(
              "Hemoglobin",
              "${sampleReport.hemoglobin} g/dL",
              hemoglobinStatus(),
              Colors.green,
            ),

            resultCard(
              "HbA1c",
              "${sampleReport.hba1c} %",
              hba1cStatus(),
              Colors.orange,
            ),

            resultCard(
              "Vitamin D",
              "${sampleReport.vitaminD} ng/mL",
              vitaminDStatus(),
              Colors.red,
            ),

            resultCard(
              "Blood Group",
              sampleReport.bloodGroup,
              "Normal",
              Colors.green,
            ),

            const SizedBox(height: 30),

            const Text(
              "AI Health Summary",
              style: TextStyle(
                fontSize: 24,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 15),

            Card(
              color: Colors.blue.shade50,
              child: const Padding(
                padding: EdgeInsets.all(16),
                child: Text(
                  "This summary is currently using sample data.\n\n"
                  "In the coming days it will be generated automatically "
                  "using OCR + OpenAI.",
                  style: TextStyle(
                    fontSize: 16,
                    height: 1.5,
                  ),
                ),
              ),
            ),

            const SizedBox(height: 25),

            SizedBox(
              width: double.infinity,
              height: 50,
              child: ElevatedButton(
                onPressed: () {
                  Navigator.popUntil(
                    context,
                    (route) => route.isFirst,
                  );
                },
                child: const Text(
                  "Back to Dashboard",
                ),
              ),
            ),

          ],
        ),
      ),
    );
  }
}
```

