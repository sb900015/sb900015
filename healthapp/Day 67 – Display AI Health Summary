import 'package:flutter/material.dart';

class ReportDetailsScreen extends StatelessWidget {
  final String fileName;

  const ReportDetailsScreen({
    super.key,
    required this.fileName,
  });

  Widget resultCard(
    String test,
    String value,
    String status,
    Color color,
  ) {
    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: ListTile(
        title: Text(
          test,
          style: const TextStyle(
            fontWeight: FontWeight.bold,
          ),
        ),
        subtitle: Text(value),
        trailing: Text(
          status,
          style: TextStyle(
            color: color,
            fontWeight: FontWeight.bold,
          ),
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {

    return Scaffold(

      appBar: AppBar(
        title: const Text("Blood Report Analysis"),
        centerTitle: true,
      ),

      body: SingleChildScrollView(

        padding: const EdgeInsets.all(20),

        child: Column(

          crossAxisAlignment: CrossAxisAlignment.start,

          children: [

            const Text(
              "Blood Report Results",
              style: TextStyle(
                fontSize: 28,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 10),

            Text(
              fileName,
              style: const TextStyle(
                color: Colors.grey,
              ),
            ),

            const SizedBox(height: 25),

            resultCard(
              "Hemoglobin",
              "13.8 g/dL",
              "Normal",
              Colors.green,
            ),

            resultCard(
              "HbA1c",
              "6.1 %",
              "Pre-Diabetic",
              Colors.orange,
            ),

            resultCard(
              "Vitamin D",
              "18 ng/mL",
              "Low",
              Colors.red,
            ),

            resultCard(
              "Blood Group",
              "B+",
              "Normal",
              Colors.green,
            ),

            const SizedBox(height: 30),

            const Text(
              "AI Health Summary",
              style: TextStyle(
                fontSize: 24,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 15),

            Card(
              color: Colors.blue.shade50,
              child: const Padding(
                padding: EdgeInsets.all(16),
                child: Text(
                  "• Your hemoglobin level is within the normal range.\n\n"
                  "• Your HbA1c indicates pre-diabetes. Regular exercise and a balanced diet may help improve blood sugar control.\n\n"
                  "• Your Vitamin D level is low. Consult your doctor about supplementation and spend some time in sunlight if appropriate.\n\n"
                  "• Overall, your health looks stable, but improving Vitamin D and monitoring HbA1c would be beneficial.",
                  style: TextStyle(
                    fontSize: 16,
                    height: 1.5,
                  ),
                ),
              ),
            ),

            const SizedBox(height: 25),

            const Text(
              "Overall Health Score",
              style: TextStyle(
                fontSize: 24,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 15),

            Card(
              color: Colors.green.shade50,
              child: const Padding(
                padding: EdgeInsets.all(20),
                child: Center(
                  child: Column(
                    children: [

                      Text(
                        "82 / 100",
                        style: TextStyle(
                          fontSize: 42,
                          fontWeight: FontWeight.bold,
                          color: Colors.green,
                        ),
                      ),

                      SizedBox(height: 10),

                      Text(
                        "Good Health",
                        style: TextStyle(
                          fontSize: 20,
                        ),
                      ),

                    ],
                  ),
                ),
              ),
            ),

            const SizedBox(height: 30),

            SizedBox(
              width: double.infinity,
              height: 50,

              child: ElevatedButton(

                onPressed: () {

                  Navigator.popUntil(
                    context,
                    (route) => route.isFirst,
                  );

                },

                child: const Text(
                  "Back to Dashboard",
                ),

              ),

            ),

          ],

        ),

      ),

    );

  }

}
