```dart
import 'dart:async';

import 'package:flutter/material.dart';

import '../models/blood_report.dart';
import '../services/ocr_service.dart';
import 'report_details_screen.dart';

class UploadProgressScreen extends StatefulWidget {

  final String fileName;

  const UploadProgressScreen({

    super.key,

    required this.fileName,

  });

  @override
  State<UploadProgressScreen> createState() =>
      _UploadProgressScreenState();

}

class _UploadProgressScreenState
    extends State<UploadProgressScreen> {

  bool uploadCompleted = false;

  BloodReport? report;

  @override
  void initState() {

    super.initState();

    loadReport();

  }

  Future<void> loadReport() async {

    OCRService service = OCRService();

    report = await service.analyzeReport(widget.fileName);

    Timer(const Duration(seconds: 2), () {

      setState(() {

        uploadCompleted = true;

      });

    });

  }

  @override
  Widget build(BuildContext context) {

    return Scaffold(

      appBar: AppBar(

        title: const Text("Uploading Report"),

      ),

      body: Center(

        child: uploadCompleted

            ? Column(

                mainAxisAlignment: MainAxisAlignment.center,

                children: [

                  const Icon(

                    Icons.check_circle,

                    color: Colors.green,

                    size: 100,

                  ),

                  const SizedBox(height: 20),

                  ElevatedButton(

                    onPressed: () {

                      Navigator.pushReplacement(

                        context,

                        MaterialPageRoute(

                          builder: (_) => ReportDetailsScreen(

                            fileName: widget.fileName,

                            report: report!,

                          ),

                        ),

                      );

                    },

                    child: const Text(

                      "View Report",

                    ),

                  ),

                ],

              )

            : const Column(

                mainAxisAlignment: MainAxisAlignment.center,

                children: [

                  CircularProgressIndicator(),

                  SizedBox(height: 20),

                  Text(

                    "Analyzing Report...",

                  ),

                ],

              ),

      ),

    );

  }

}
```

