## `lib/screens/report_details_screen.dart`

```dart
import 'package:flutter/material.dart';

class ReportDetailsScreen extends StatelessWidget {

  final Map report;

  const ReportDetailsScreen({
    super.key,
    required this.report,
  });

  @override
  Widget build(BuildContext context) {

    double hemoglobin =
        double.parse(report["hemoglobin"].toString());

    String status =
        hemoglobin >= 12 ? "Normal" : "Low";

    Color statusColor =
        hemoglobin >= 12 ? Colors.green : Colors.red;

    String interpretation =
        hemoglobin >= 12
            ? "Hemoglobin is within the normal range. This usually indicates a healthy oxygen-carrying capacity of the blood."
            : "Hemoglobin is below the normal range. This may indicate anemia or iron deficiency. Please consult a healthcare professional.";

    String aiExplanation =
        hemoglobin >= 12
            ? "Your hemoglobin value appears to be healthy. Continue maintaining a balanced diet, stay hydrated, exercise regularly, and schedule routine health checkups."
            : "Your hemoglobin value is lower than the normal range. Low hemoglobin can sometimes be associated with iron deficiency or anemia. Consider consulting your healthcare provider for further evaluation and treatment if needed.";

    return Scaffold(

      appBar: AppBar(
        title: const Text("Blood Report Details"),
      ),

      body: SingleChildScrollView(

        padding: const EdgeInsets.all(20),

        child: Column(

          children: [

            const CircleAvatar(

              radius: 50,

              child: Icon(
                Icons.person,
                size: 60,
              ),

            ),

            const SizedBox(height: 20),

            Text(

              report["patient_name"],

              style: const TextStyle(

                fontSize: 28,

                fontWeight: FontWeight.bold,

              ),

            ),

            const SizedBox(height: 10),

            Container(

              padding: const EdgeInsets.symmetric(
                horizontal: 20,
                vertical: 10,
              ),

              decoration: BoxDecoration(

                color: statusColor,

                borderRadius:
                    BorderRadius.circular(20),

              ),

              child: Text(

                status,

                style: const TextStyle(

                  color: Colors.white,

                  fontWeight: FontWeight.bold,

                  fontSize: 18,

                ),

              ),

            ),

            const SizedBox(height: 30),

            Card(

              elevation: 5,

              child: Padding(

                padding: const EdgeInsets.all(18),

                child: Column(

                  children: [

                    ListTile(

                      leading: const Icon(Icons.numbers),

                      title: const Text("Report ID"),

                      trailing: Text(
                        report["id"].toString(),
                      ),

                    ),

                    const Divider(),

                    ListTile(

                      leading: const Icon(Icons.person),

                      title: const Text("Patient Name"),

                      trailing: Text(
                        report["patient_name"],
                      ),

                    ),

                    const Divider(),

                    ListTile(

                      leading: const Icon(
                        Icons.favorite,
                        color: Colors.red,
                      ),

                      title: const Text("Hemoglobin"),

                      trailing: Text(
                        report["hemoglobin"].toString(),
                      ),

                    ),

                  ],

                ),

              ),

            ),

            const SizedBox(height: 25),

            Card(

              color: Colors.orange.shade50,

              elevation: 4,

              child: Padding(

                padding: const EdgeInsets.all(18),

                child: Column(

                  crossAxisAlignment:
                      CrossAxisAlignment.start,

                  children: [

                    const Row(

                      children: [

                        Icon(
                          Icons.medical_information,
                          color: Colors.orange,
                        ),

                        SizedBox(width: 10),

                        Text(

                          "Health Interpretation",

                          style: TextStyle(

                            fontSize: 22,

                            fontWeight: FontWeight.bold,

                          ),

                        ),

                      ],

                    ),

                    const SizedBox(height: 20),

                    Text(

                      interpretation,

                      style: const TextStyle(
                        fontSize: 17,
                      ),

                    ),

                  ],

                ),

              ),

            ),

            const SizedBox(height: 25),

            Card(

              color: Colors.blue.shade50,

              elevation: 4,

              child: Padding(

                padding: const EdgeInsets.all(18),

                child: Column(

                  crossAxisAlignment:
                      CrossAxisAlignment.start,

                  children: [

                    const Row(

                      children: [

                        Icon(
                          Icons.smart_toy,
                          color: Colors.blue,
                        ),

                        SizedBox(width: 10),

                        Text(

                          "AI Explanation",

                          style: TextStyle(

                            fontSize: 22,

                            fontWeight: FontWeight.bold,

                          ),

                        ),

                      ],

                    ),

                    const SizedBox(height: 20),

                    Text(

                      aiExplanation,

                      style: const TextStyle(
                        fontSize: 17,
                      ),

                    ),

                  ],

                ),

              ),

            ),

          ],

        ),

      ),

    );

  }

}
