---
- name: This playbook is to install packages using variables
  hosts: all
  become: true
  
  vars:
    app: docker

  tasks:
    - name: Install package {{app}}
      package:
        name: "{{app}}"
        state: present
    - name: enable service for {{App}}
      service:
        name: "{{app}}"
        state: started
...
